{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Omni Palette Tauri Wireframe",
  "version": "0.1.0",
  "identifier": "dev.omnipalette.wireframe",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Omni Palette",
        "label": "main",
        "width": 960,
        "height": 640,
        "resizable": true,
        "decorations": true,
        "visible": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": "all"
  }
}
