{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Omni Palette Tauri Wireframe",
  "version": "0.1.0",
  "identifier": "dev.omnipalette.wireframe",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Omni Palette",
        "label": "main",
        "width": 780,
        "height": 500,
        "resizable": false,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visible": false
      },
      {
        "title": "Omni Palette Settings",
        "label": "settings",
        "width": 960,
        "height": 680,
        "resizable": true,
        "decorations": true,
        "visible": false
      },
      {
        "title": "Omni Palette Guide",
        "label": "guide",
        "width": 560,
        "height": 218,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": "all"
  }
}
